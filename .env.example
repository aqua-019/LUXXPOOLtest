# ═══════════════════════════════════════════════════
# LUXXPOOL v0.8.1 — Environment Configuration
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════

# ── Fleet Configuration (40+ L9 Miners) ──────────
FLEET_IPS=10.0.0.0/24                    # CIDR block covering facility (comma-separated for multiple)
FLEET_ADDRESSES=                          # Optional: LTC addresses (comma-separated)
FLEET_FEE=0                               # 0% fee for fleet miners
FLEET_MAX_MINERS=100                      # Max fleet capacity (increase as fleet grows)

# ── Pool Fees ─────────────────────────────────────
POOL_FEE=0.02                             # 2% for public miners
SOLO_FEE=0.01                             # 1% for solo miners
POOL_FEE_ADDRESS=                         # LTC address for fee collection (required if POOL_FEE > 0)

# ── Litecoin Daemon ───────────────────────────────
LTC_HOST=127.0.0.1
LTC_PORT=9332
LTC_USER=luxxpool
LTC_PASS=
LTC_ZMQ_ENABLED=true
LTC_ZMQ_HOST=127.0.0.1
LTC_ZMQ_PORT=28332

# ── Auxiliary Chains (merged mining) ──────────────
# Each chain: <SYMBOL>_HOST, _PORT, _USER, _PASS, _ADDRESS
# Enabled chains: DOGE, BELLS, LKY, PEP, JKC, DINGO, SHIC
# Disabled (needs nodes): TRMP, CRC
DOGE_HOST=127.0.0.1
DOGE_PORT=22555
DOGE_USER=luxxpool
DOGE_PASS=
DOGE_ADDRESS=

# ── PostgreSQL ────────────────────────────────────
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=luxxpool
PG_PASS=
PG_DATABASE=luxxpool

# ── Redis ─────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ── API ───────────────────────────────────────────
API_PORT=8080
API_HOST=0.0.0.0
API_ADMIN_TOKEN=                          # Min 32 chars for security
API_CORS_ORIGIN=http://localhost:3000

# ── Payment ───────────────────────────────────────
PAYMENT_ENABLED=true
PAYMENT_INTERVAL=600                      # Seconds between payment cycles
PAYMENT_MIN_PAYOUT=0.01                   # Minimum LTC payout
PPLNS_WINDOW=100                          # Blocks in PPLNS window (~4.2 hours)

# ── Stratum ───────────────────────────────────────
STRATUM_PORT=3333
STRATUM_SSL_PORT=3334
STRATUM_SOLO_PORT=3336

# ── Security ──────────────────────────────────────
SEC_MAX_CONN_PER_IP=5                     # Public: connections per IP
SEC_MAX_CONN_PER_FLEET_IP=100             # Fleet: connections per IP
SEC_MAX_SHARE_RATE_PER_MIN=600            # Shares/min per client
DDOS_MAX_CONNECTIONS_PER_IP=5             # Stratum-level public limit
